{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git config --unset-all core.hooksPath 2>/dev/null; python -m pre_commit install --hook-type commit-msg 2>/dev/null || true",
            "statusMessage": "Installing pre-commit hooks",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./ai/scripts/save-prompt/hook.sh 'claude'",
            "async": true
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(tree:*)",
      "Bash(ls:*)",
      "Bash(yarn)",
      "Bash(make)",
      "Bash(which python)",
      "Bash(python --version)",
      "Bash(pip show:*)",
      "Bash(pip3 show:*)",
      "Bash(uv pip show:*)",
      "Bash(pip index versions:*)",
      "Bash(pip3 index versions:*)",
      "Bash(uv pip index versions:*)",
      "Bash(uv --version)",
      "Bash(uv python list)",
      "Bash(uv pip index versions:*)",
      "Bash(poetry install:*)",
      "Bash(yarn install:*)",
      "Bash(uv sync:*)",
      "Bash(yarn type-check:*)",
      "Bash(yarn lint:*)",
      "Bash(yarn tsc:*)",
      "Bash(npx vue-tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(uv run ruff check:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run python -m pytest:*)",
      "Bash(poetry run pytests:*)",
      "Bash(yarn test:unit:*)",
      "Bash(cargo test:*)",
      "Bash(yarn build-check:*)",
      "Bash(yarn run type-check:*)",
      "Bash(yarn run lint:*)",
      "Bash(yarn run tsc:*)",
      "Bash(yarn lint:*)",
      "Bash(yarn eslint:*)",
      "Bash(yarn fix:*)",
      "Bash(yarn build:*)",
      "Bash(uv add:*)",
      "Bash(cargo check:*)",
      "Bash(.claude/hooks/save-prompt.sh)",
      "Bash(echo \"exit: $?\")",
      "Bash(git add:*)",
      "Bash(git diff --stat)",
      "Bash(git status:*)",
      "Bash(git status --short)",
      "Bash(git branch --show-current)",
      "Bash(git ls-tree:*)",
      "Bash(git fetch:*)",
      "Bash(git check-ignore:*)",
      "Bash(make commit:*)"
    ]
  },
  "deny": [
    "Bash(git add .)",
    "Bash(git add .:*)",
    "Bash(git add -A)",
    "Bash(git add -A:*)"
  ]
}
