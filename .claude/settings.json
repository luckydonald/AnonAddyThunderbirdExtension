{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash|shell|unified_exec",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.claude/hooks/permission-check.py\"",
            "timeout": 5,
            "statusMessage": "Checking command policy..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/°base/ai/settings/sync.py\" --apply",
            "statusMessage": "Syncing AI tool settings",
            "async": true
          },
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/scripts/°base/init/checkout.sh\"",
            "statusMessage": "Setting up git hooks",
            "async": true
          },
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/°base/ai/hooks/record-memory/hook.py\"",
            "statusMessage": "Syncing memory hardlinks",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "AskUserQuestion|request_user_input",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/°base/ai/hooks/save-decision/hook.py\" 'claude'",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/°base/ai/hooks/record-memory/hook.py\"",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/°base/ai/hooks/save-plan/hook.py\" 'claude'",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/°base/ai/hooks/save-plan/hook.py\" 'claude'",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/°base/ai/hooks/save-prompt/hook.py\" 'claude'",
            "async": true
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(tree:*)",
      "Bash(ls:*)",
      "Bash(yarn)",
      "Bash(make)",
      "Bash(which python)",
      "Bash(python --version)",
      "Bash(pip show:*)",
      "Bash(pip3 show:*)",
      "Bash(uv pip show:*)",
      "Bash(pip index versions:*)",
      "Bash(pip3 index versions:*)",
      "Bash(uv --version)",
      "Bash(uv python list)",
      "Bash(uv pip index versions:*)",
      "Bash(nvm use:*)",
      "Bash(poetry install:*)",
      "Bash(yarn install:*)",
      "Bash(uv sync:*)",
      "Bash(uv lock *)",
      "Bash(npx vue-tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(uv run ruff check:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run python -m pytest:*)",
      "Bash(poetry run pytests:*)",
      "Bash(python3 -m unittest ai.scripts.tests.test_permission_check:*)",
      "Bash(python3 -m unittest ai.scripts.tests.test_permission_check.IntegrationTests.test_git_commit_heredoc_prose_mention_allowed:*)",
      "Bash(python3 -m unittest ai.scripts.tests.test_permission_check.CheckGitCommitTests.test_co_authored_by_heredoc_caught_by_shlex_path:*)",
      "Bash(yarn test:unit:*)",
      "Bash(yarn test:coverage:*)",
      "Bash(cargo test:*)",
      "Bash(yarn build-check:*)",
      "Bash(yarn run type-check)",
      "Bash(yarn run type-check:*)",
      "Bash(yarn run lint)",
      "Bash(yarn run lint:*)",
      "Bash(yarn run tsc:*)",
      "Bash(yarn type-check:*)",
      "Bash(yarn lint:*)",
      "Bash(yarn eslint:*)",
      "Bash(yarn tsc:*)",
      "Bash(yarn fix:*)",
      "Bash(yarn build:*)",
      "Bash(yarn test:unit)",
      "Bash(yarn run test:unit)",
      "Bash(cargo check:*)",
      "Bash(uv add:*)",
      "Bash(echo \"exit: $?\")",
      "Bash(git add:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git branch --show-current)",
      "Bash(git ls-tree:*)",
      "Bash(git check-ignore:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git commit -F ai/git/pending-commit.md)",
      "Bash(make commit:*)",
      "Bash(rm ai/git/pending-commit.md || echo 'was gone')",
      "Bash(rm ai/git/pending-commit.md)",
      "Bash(git lfs install)",
      "Bash(command -v pre-commit)",
      "Bash(git rebase --continue)",
      "Bash(pkill -f \"vite\")",
      "Bash(tree)",
      "Skill(rebase-ai-prompt-commits)",
      "Skill(/rebase-ai-prompt-commits)",
      "Skill(committing-with-lplp-style)",
      "Skill(/committing-with-lplp-style)",
      "Bash(uv run --project scripts/°base python -m unittest ai.scripts.tests.test_git_remote_fix ai.scripts.tests.test_git_remote_fix_tui_tdd ai.scripts.tests.test_git_remote_fix_tui_terminal -v)",
      "Bash(uv run --project scripts/°base python -m unittest discover -s scripts/°base/tests -v)",
      "Bash(python3 scripts/°base/ai/hooks/save-prompt/hook.py)",
      "Bash(python3 -m pytest scripts/°base/tests/test_permission_check.py:*)",
      "Bash(python3 -m pytest scripts/°base/init/checkout.sh)",
      "Bash(GIT_SEQUENCE_EDITOR=/tmp/git-rebase-todo.sh git *)",
      "Bash(uv run fastapi --help)",
      "Bash(echo \"---\")"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/env.php*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/docker-compose*.yml)",
      "Read(**/config/database.yml)"
    ]
  }
}
