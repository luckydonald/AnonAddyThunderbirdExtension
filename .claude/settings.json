{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./ai/scripts/hooks/save-prompt/hook.sh 'claude'",
            "async": true
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(poetry install:*)",
      "Bash(yarn install:*)",
      "Bash(uv sync:*)",
      "Bash(uv run ruff check:*)",
      "Bash(uv run pytest:*)",
      "Bash(poetry run pytests:*)",
      "Bash(yarn test:unit:*)",
      "Bash(yarn run type-check:*)",
      "Bash(yarn run lint:*)",
      "Bash(./scripts/append_and_clear_summary.sh)",
      "Bash(.claude/hooks/save-prompt.sh)",
      "Bash(echo \"exit: $?\")",
      "Bash(make commit:*)"
    ]
  }
}
