{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "short_name": "__MSG_extensionShortName__",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "version": "0.0.4",
  "browser_specific_settings": {
    "gecko": {
      "id": "AnonAddyTB@kamens.us",
      "strict_min_version": "128.0",
      // Experiments must target ESR to avoid monthly breakage.
      // Update this when a newer ESR is released.
      "strict_max_version": "140.*"
    }
  },
  "experiment_apis": {
    "AddressChipMenu": {
      "schema": "experiment/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["AddressChipMenu"]],
        "script": "experiment/implementation.js",
        "events": ["startup"]
      }
    }
  },
  "host_permissions": ["*://app.addy.io/"],
  "optional_host_permissions": ["*://*/"],
  "permissions": ["activeTab", "alarms", "compose", "storage"],
  "compose_action": {
    "default_area": "maintoolbar",
    "default_title": "Addy",
    "default_icon": "icon.svg",
    "default_popup": "./composePopup.html"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "options.html"
  },
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  }
}
