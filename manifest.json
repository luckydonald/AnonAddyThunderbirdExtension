{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "short_name": "__MSG_extensionShortName__",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "version": "0.0.6",
  "browser_specific_settings": {
    "gecko": {
      "id": "AnonAddyTB@luckydonald.de",
      "strict_min_version": "140.0"
    }
  },
  "experiment_apis": {
    "AddressChipMenu": {
      "schema": "experiment/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["AddressChipMenu"]],
        "script": "experiment/implementation.js"
      }
    }
  },
  "host_permissions": ["*://app.addy.io/"],
  "optional_host_permissions": ["*://*/*"],
  "permissions": ["alarms", "compose", "storage"],
  "compose_action": {
    "default_area": "maintoolbar",
    "default_title": "Addy",
    "default_icon": "icon.svg"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "options.html"
  },
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  }
}
